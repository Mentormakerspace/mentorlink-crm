# Backend Environment Variables Template  
# Copy this file to .env and fill in your actual values

# PostgreSQL Database Configuration
# For production, use your actual database credentials
DB_USERNAME=your_db_username
DB_PASSWORD=your_secure_db_password
DB_HOST=your_db_host
DB_PORT=5432
DB_NAME=your_db_name

# Flask Configuration
FLASK_APP=src/main.py
FLASK_ENV=production
SECRET_KEY=your_very_secure_secret_key_here_change_this

# Optional: Supabase JWT Secret (if implementing backend JWT validation)
# SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Optional: API Base URL (if needed by backend)
# API_BASE_URL=https://your-backend-domain.com/api
